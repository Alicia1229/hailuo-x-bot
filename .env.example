# ===== X 凭证（用浏览器登录态即可，无需付费 API）=====
# 从 https://x.com 登录后，浏览器 DevTools → Application → Cookies → x.com
# 找 auth_token 和 ct0 两个值，照下面格式填。
X_ACCOUNTS_DB=./accounts.db
# 多个账号可写多行；一个就够。
X_QUERY_LANG=en

# ===== 飞书自定义机器人 Webhook =====
# 群 → 设置 → 群机器人 → 添加机器人 → 自定义机器人 → 复制 Webhook 地址
FEISHU_WEBHOOK_URL=
# 如果在机器人安全设置里勾了"签名校验"，把 Secret 也填上
FEISHU_SECRET=

# ===== 关键词（OR 关系，命中任一就收）=====
KEYWORDS=hailuo03,hailuo3,hailuo,hailuoai,MiniMax Video,MiniMax H3

# ===== 推送时间（24h 制）=====
PUSH_HOUR=19
PUSH_MINUTE=0

# ===== 时区 =====
TZ=Asia/Shanghai